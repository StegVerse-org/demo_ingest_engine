{
  "repos": {
    "demo_ingest_engine": {
      "repo_slug": "demo_ingest_engine",
      "clone_url": "https://github.com/StegVerse-org/demo_ingest_engine.git",
      "default_branch": "main",
      "allowed_prefixes": [
        "ingest/",
        "configs/",
        "incoming/",
        "staging/",
        "reports/",
        "deprecated/",
        "updated_targets/",
        ".github/",
        "README.md",
        "requirements.txt",
        "LICENSE",
        "ARTIFACT_EVALUATION.md"
      ]
    },
    "demo_suite_runner": {
      "repo_slug": "demo-suite-runner",
      "clone_url": "https://github.com/StegVerse-org/demo-suite-runner.git",
      "default_branch": "main",
      "allowed_prefixes": [
        "runner/",
        "configs/",
        "scripts/",
        "reports/",
        "runs/",
        ".github/",
        "README.md",
        "requirements.txt",
        "LICENSE",
        "ARTIFACT_EVALUATION.md"
      ]
    },
    "stegverse_demo_suite": {
      "repo_slug": "stegverse-demo-suite",
      "clone_url": "https://github.com/StegVerse-org/stegverse-demo-suite.git",
      "default_branch": "main",
      "allowed_prefixes": [
        "docs/",
        "engine/",
        "workflow/",
        "theory/",
        ".github/",
        "README.md",
        "stegverse",
        "stegverse.cmd",
        "LICENSE",
        "ARTIFACT_EVALUATION.md",
        "REPRODUCIBILITY.md"
      ]
    },
    "stegverse_gsl": {
      "repo_slug": "stegverse-gsl",
      "clone_url": "https://github.com/StegVerse-org/stegverse-gsl.git",
      "default_branch": "main",
      "allowed_prefixes": [
        "sdk_assistant/",
        "schemas/",
        "engine/",
        "buildout/",
        "sandbox/",
        "receipts/",
        "tests/",
        "config/",
        "examples/",
        "docs/",
        ".github/",
        "buildout.yaml",
        "README.md",
        "requirements.txt",
        "LICENSE",
        "ARTIFACT_EVALUATION.md",
        "REPRODUCIBILITY.md"
      ]
    }
  },
  "repo_aliases": {
    "demo_ingest_engine": "demo_ingest_engine",
    "demo-ingest-engine": "demo_ingest_engine",
    "demo_suite_runner": "demo_suite_runner",
    "demo-suite-runner": "demo_suite_runner",
    "stegverse_demo_suite": "stegverse_demo_suite",
    "stegverse-demo-suite": "stegverse_demo_suite",
    "stegverse_gsl": "stegverse_gsl",
    "stegverse-gsl": "stegverse_gsl"
  },
  "target_sets": {
    "all": [
      "demo_ingest_engine",
      "demo_suite_runner",
      "stegverse_demo_suite",
      "stegverse_gsl"
    ],
    "runtime_stack": [
      "demo_suite_runner",
      "stegverse_demo_suite"
    ],
    "gsl_stack": [
      "stegverse_gsl"
    ]
  }
}
